enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum SubscriptionTier {
  FREE
  PRO
  TEAM
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CITIZEN
  MP
  ADMIN
}

enum VerificationStatus {
  NONE
  EMAIL
  ADDRESS
  IDENTITY
}

enum VotePosition {
  SUPPORT
  OPPOSE
  ABSTAIN
}

enum BillStageType {
  INTRODUCED
  FIRST_READING
  SECOND_READING
  COMMITTEE
  THIRD_READING
  PASSED
  ROYAL_ASSENT
}

enum BillChamber {
  HOUSE
  SENATE
  JOINT
}

model User {
  id              String      @id @default(cuid())
  email           String      @unique
  emailVerified   DateTime?
  role            UserRole    @default(CITIZEN)
  verifiedAt      DateTime?
  termsAcceptedAt DateTime?
  electorateId    String?
  electorate      Electorate? @relation(fields: [electorateId], references: [id], onDelete: SetNull)
  addressHash          String?
  verificationStatus   VerificationStatus @default(NONE)
  electorateVerified   Boolean    @default(false)
  name            String?
  image           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  stripeCustomerId    String?  @unique
  subscriptionStatus  SubscriptionStatus @default(TRIAL)
  subscriptionTier    SubscriptionTier   @default(FREE)
  trialEndsAt         DateTime?
  subscriptionId      String?
  votes           Vote[]
  mpSentiments    MpSentiment[]
  accounts        Account[]
  sessions        Session[]

  @@index([role])
  @@index([electorateId])
  @@index([verifiedAt])
}

model Electorate {
  id        String   @id
  name      String   @unique
  state     String
  mpName    String?
  mpParty   String?
  mpEmail     String?
  mpPhotoUrl  String?
  mpChamber   String?
  mpId        String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  votes     Vote[]

  @@index([state])
}

model Bill {
  id            String      @id @default(cuid())
  title         String
  summary       String?
  chamber       BillChamber
  status        String
  sponsorName   String?
  portfolio     String?
  aphUrl        String      @unique
  aphDescription String?
  aiSummary      String?
  revisionsCount Int     @default(0)
  hasAmendments  Boolean @default(false)
  committees     String?
  fullText       String?
  fullTextFetchedAt DateTime?
  pdfUrl         String?
  lastCheckedAt  DateTime?
  nextReviewAt   DateTime?
  introducedAt  DateTime?
  outcome       String?
  parliamentaryProgress String?
  divisionsData     String?
  parliamentNumber  Int?
  outcomeDate   DateTime?
  lastUpdatedAt DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  stages        BillStage[]
  votes         Vote[]

  @@index([status])
  @@index([chamber])
  @@index([portfolio])
  @@index([lastUpdatedAt])
}

model Vote {
  id           String       @id @default(cuid())
  userId       String
  billId       String
  electorateId String?
  position             VotePosition
  verificationStatus   VerificationStatus @default(NONE)
  comment      String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  bill         Bill         @relation(fields: [billId], references: [id], onDelete: Cascade)
  electorate   Electorate?  @relation(fields: [electorateId], references: [id], onDelete: SetNull)

  @@unique([userId, billId])
  @@index([billId, position])
  @@index([electorateId, billId])
}

model BillStage {
  id         String        @id @default(cuid())
  billId     String
  stage      BillStageType
  recordedAt DateTime
  bill       Bill          @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId, recordedAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum SentimentValue {
  POSITIVE
  NEGATIVE
}

model MpSentiment {
  id        String         @id @default(cuid())
  userId    String
  mpId      String
  sentiment SentimentValue
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mpId])
  @@index([mpId])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
