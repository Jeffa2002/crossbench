generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CITIZEN
  MP
  ADMIN
}

enum VotePosition {
  SUPPORT
  OPPOSE
  ABSTAIN
}

enum BillStageType {
  INTRODUCED
  FIRST_READING
  SECOND_READING
  COMMITTEE
  THIRD_READING
  PASSED
  ROYAL_ASSENT
}

enum BillChamber {
  HOUSE
  SENATE
  JOINT
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified DateTime?
  role          UserRole   @default(CITIZEN)
  verifiedAt    DateTime?
  electorateId  String?
  electorate    Electorate? @relation(fields: [electorateId], references: [id], onDelete: SetNull)
  addressHash   String?    @unique
  name          String?
  image         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  votes         Vote[]
  accounts      Account[]
  sessions      Session[]

  @@index([role])
  @@index([electorateId])
  @@index([verifiedAt])
}

model Electorate {
  id        String   @id
  name      String   @unique
  state     String
  mpName    String?
  mpParty   String?
  mpEmail   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  votes     Vote[]

  @@index([state])
}

model Bill {
  id            String      @id @default(cuid())
  title         String
  summary       String?
  chamber       BillChamber
  status        String
  sponsorName   String?
  portfolio     String?
  aphUrl        String      @unique
  introducedAt  DateTime?
  lastUpdatedAt DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  stages        BillStage[]
  votes         Vote[]

  @@index([status])
  @@index([chamber])
  @@index([portfolio])
  @@index([lastUpdatedAt])
}

model Vote {
  id           String       @id @default(cuid())
  userId       String
  billId       String
  electorateId String?
  position     VotePosition
  comment      String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  bill         Bill         @relation(fields: [billId], references: [id], onDelete: Cascade)
  electorate   Electorate?  @relation(fields: [electorateId], references: [id], onDelete: SetNull)

  @@unique([userId, billId])
  @@index([billId, position])
  @@index([electorateId, billId])
}

model BillStage {
  id         String        @id @default(cuid())
  billId     String
  stage      BillStageType
  recordedAt DateTime
  bill       Bill          @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId, recordedAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
