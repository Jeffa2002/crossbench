enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum SubscriptionTier {
  FREE
  PRO
  TEAM
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CITIZEN
  MP
  ADMIN
}

enum VerificationStatus {
  NONE
  EMAIL
  ADDRESS
  IDENTITY
}

enum VotePosition {
  SUPPORT
  OPPOSE
  ABSTAIN
}

enum BillStageType {
  INTRODUCED
  FIRST_READING
  SECOND_READING
  COMMITTEE
  THIRD_READING
  PASSED
  ROYAL_ASSENT
}

enum BillChamber {
  HOUSE
  SENATE
  JOINT
}

model User {
  id              String      @id @default(cuid())
  email           String      @unique
  emailVerified   DateTime?
  role            UserRole    @default(CITIZEN)
  verifiedAt      DateTime?
  termsAcceptedAt DateTime?
  electorateId    String?
  electorate      Electorate? @relation(fields: [electorateId], references: [id], onDelete: SetNull)
  addressHash             String?
  addressChangeCount      Int        @default(0)
  lastAddressChangeAt     DateTime?
  verificationStatus      VerificationStatus @default(NONE)
  electorateVerified   Boolean    @default(false)
  name            String?
  image           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  stripeCustomerId    String?  @unique
  subscriptionStatus  SubscriptionStatus @default(TRIAL)
  subscriptionTier    SubscriptionTier   @default(FREE)
  trialEndsAt         DateTime?
  subscriptionId      String?
  votes           Vote[]
  mpSentiments    MpSentiment[]
  supportTickets     SupportTicket[]
  addressChangeLogs  AddressChangeLog[]
  accounts           Account[]
  sessions        Session[]
  billAlerts         BillAlert[]
  officeMemberships  OfficeMembership[] @relation("OfficeMembershipUser")
  invitedOfficeMemberships OfficeMembership[] @relation("OfficeMembershipInviter")
  officeInvitesSent OfficeInvite[] @relation("OfficeInviteInviter")
  officeInvitesAccepted OfficeInvite[] @relation("OfficeInviteAcceptedBy")
  officeAuditEvents OfficeAuditEvent[] @relation("OfficeAuditActor")

  @@index([role])
  @@index([electorateId])
  @@index([verifiedAt])
}

model Electorate {
  id        String   @id
  name      String   @unique
  state     String
  mpName    String?
  mpParty   String?
  mpEmail     String?
  mpPhotoUrl  String?
  mpChamber   String?
  mpId        String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  votes     Vote[]
  officeMemberships OfficeMembership[]
  officeInvites OfficeInvite[]
  officeAuditEvents OfficeAuditEvent[]

  @@index([state])
}

model Bill {
  id            String      @id @default(cuid())
  title         String
  summary       String?
  chamber       BillChamber
  status        String
  sponsorName   String?
  portfolio     String?
  aphUrl        String      @unique
  aphDescription String?
  aiSummary      String?
  revisionsCount Int     @default(0)
  hasAmendments  Boolean @default(false)
  committees     String?
  fullText       String?
  fullTextFetchedAt DateTime?
  pdfUrl         String?
  lastCheckedAt  DateTime?
  nextReviewAt   DateTime?
  introducedAt  DateTime?
  outcome       String?
  parliamentaryProgress String?
  divisionsData     String?
  parliamentNumber  Int?
  outcomeDate   DateTime?
  lastUpdatedAt DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  stages        BillStage[]
  votes         Vote[]

  @@index([status])
  @@index([chamber])
  @@index([portfolio])
  @@index([lastUpdatedAt])
  @@index([parliamentNumber])
}

model Vote {
  id           String       @id @default(cuid())
  userId       String
  billId       String
  electorateId String?
  position             VotePosition
  verificationStatus   VerificationStatus @default(NONE)
  comment      String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  bill         Bill         @relation(fields: [billId], references: [id], onDelete: Cascade)
  electorate   Electorate?  @relation(fields: [electorateId], references: [id], onDelete: SetNull)

  @@unique([userId, billId])
  @@index([billId, position])
  @@index([electorateId, billId])
}

model BillStage {
  id         String        @id @default(cuid())
  billId     String
  stage      BillStageType
  recordedAt DateTime
  bill       Bill          @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId, recordedAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum SentimentValue {
  POSITIVE
  NEGATIVE
}

model MpSentiment {
  id        String         @id @default(cuid())
  userId    String
  mpId      String
  sentiment SentimentValue
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mpId])
  @@index([mpId])
  @@index([userId])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum OutreachEmailStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum OfficeMembershipRole {
  PRINCIPAL
  OFFICE_ADMIN
  STAFFER
}

enum OfficeMembershipStatus {
  ACTIVE
  BLOCKED
  REMOVED
}

enum OfficeInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

model AddressChangeLog {
  id               String   @id @default(cuid())
  userId           String
  fromElectorateId String?
  toElectorateId   String?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SupportTicket {
  id               String          @id @default(dbgenerated("next_support_ticket_id()"))
  userId           String?
  email            String
  name             String?
  subject          String
  message          String
  status           TicketStatus    @default(OPEN)
  priority         TicketPriority  @default(NORMAL)
  aiSuggestedReply String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  user             User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  replies          SupportReply[]

  @@index([status])
  @@index([userId])
}

model SupportReply {
  id          String        @id @default(cuid())
  ticketId    String
  authorId    String?
  authorEmail String
  isAdmin     Boolean       @default(false)
  isAi        Boolean       @default(false)
  message     String
  resendId    String?
  emailSentAt DateTime?
  emailError  String?
  createdAt   DateTime      @default(now())
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model OutreachEmailLog {
  id             String              @id @default(cuid())
  campaign       String
  electorateId   String?
  chamber        String?
  recipientName  String?
  recipientEmail String
  subject        String
  status         OutreachEmailStatus @default(PENDING)
  resendId       String?
  error          String?
  sentAt         DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([campaign, recipientEmail])
  @@index([campaign])
  @@index([status])
  @@index([electorateId])
}

model OfficeMembership {
  id              String                 @id @default(cuid())
  electorateId    String
  userId          String
  role            OfficeMembershipRole   @default(STAFFER)
  status          OfficeMembershipStatus @default(ACTIVE)
  invitedByUserId String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  removedAt       DateTime?
  blockedAt       DateTime?
  electorate      Electorate             @relation(fields: [electorateId], references: [id], onDelete: Cascade)
  user            User                   @relation("OfficeMembershipUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy       User?                  @relation("OfficeMembershipInviter", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@unique([electorateId, userId])
  @@index([userId])
  @@index([electorateId])
  @@index([status])
}

model OfficeInvite {
  id               String               @id @default(cuid())
  electorateId     String
  email            String
  name             String?
  role             OfficeMembershipRole @default(STAFFER)
  status           OfficeInviteStatus   @default(PENDING)
  tokenHash        String               @unique
  invitedByUserId  String
  acceptedByUserId String?
  expiresAt        DateTime
  acceptedAt       DateTime?
  revokedAt        DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  electorate       Electorate           @relation(fields: [electorateId], references: [id], onDelete: Cascade)
  invitedBy        User                 @relation("OfficeInviteInviter", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  acceptedBy       User?                @relation("OfficeInviteAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([electorateId])
  @@index([email])
  @@index([status])
  @@index([expiresAt])
}

model OfficeAuditEvent {
  id           String     @id @default(cuid())
  electorateId String
  actorUserId  String?
  targetUserId String?
  targetEmail  String?
  action       String
  metadata     String?
  createdAt    DateTime   @default(now())
  electorate   Electorate @relation(fields: [electorateId], references: [id], onDelete: Cascade)
  actor        User?      @relation("OfficeAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([electorateId])
  @@index([actorUserId])
  @@index([targetUserId])
  @@index([action])
  @@index([createdAt])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model BillAlert {
  id              String    @id @default(cuid())
  userId          String
  keyword         String
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastNotifiedAt  DateTime?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifications   BillAlertNotification[]

  @@unique([userId, keyword])
  @@index([isActive])
  @@index([keyword])
}

model BillAlertNotification {
  id          String    @id @default(cuid())
  alertId     String
  billId      String
  sentAt      DateTime  @default(now())
  alert       BillAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@unique([alertId, billId])
  @@index([alertId])
}

model MpNewsletterSubscription {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String?
  electorateId      String?
  source            String?
  active            Boolean   @default(true)
  unsubscribeToken  String    @unique
  subscribedAt      DateTime  @default(now())
  unsubscribedAt    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deliveries        MpNewsletterDelivery[]

  @@index([active])
  @@index([electorateId])
}

model MpNewsletterCampaign {
  id              String    @id @default(cuid())
  subject         String
  textBody        String
  htmlBody        String?
  sentBy          String
  recipientMode   String
  attachmentNames String?
  totalRecipients Int       @default(0)
  sentCount       Int       @default(0)
  failedCount     Int       @default(0)
  createdAt       DateTime  @default(now())
  sentAt          DateTime?
  deliveries      MpNewsletterDelivery[]

  @@index([createdAt])
}

model MpNewsletterDelivery {
  id             String                    @id @default(cuid())
  campaignId     String
  subscriptionId String?
  email          String
  status         String
  resendId       String?
  error          String?
  sentAt         DateTime?
  createdAt      DateTime                  @default(now())
  campaign       MpNewsletterCampaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  subscription   MpNewsletterSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([campaignId])
  @@index([subscriptionId])
  @@index([email])
  @@index([status])
}

model WebVisitSession {
  id          String        @id
  ipHash      String?
  countryCode String?
  region      String?
  city        String?
  userAgent   String?
  deviceType  String?
  browser     String?
  firstPath   String?
  lastPath    String?
  referrer    String?
  startedAt   DateTime      @default(now())
  lastSeenAt  DateTime      @default(now())
  pageViews   WebPageView[]

  @@index([countryCode])
  @@index([startedAt])
  @@index([lastSeenAt])
  @@index([ipHash])
}

model WebPageView {
  id              String          @id @default(cuid())
  sessionId       String
  path            String
  title           String?
  referrer        String?
  durationSeconds Int             @default(0)
  startedAt       DateTime        @default(now())
  endedAt         DateTime?
  session         WebVisitSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([path])
  @@index([startedAt])
  @@index([durationSeconds])
}
